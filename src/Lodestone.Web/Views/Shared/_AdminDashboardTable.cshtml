@model IReadOnlyList<AdminSectionRowDto>

<div class="ls-admin-compact-list">
    @foreach (var row in Model)
    {
        <article class="ls-admin-compact-list__item">
            <div class="ls-admin-compact-list__main">
                <strong>@row.PrimaryLabel</strong>
                <span>@row.SecondaryLabel</span>
            </div>
            <div class="ls-admin-compact-list__meta">
                @foreach (var cell in row.Cells.Take(3))
                {
                    <span>@cell.Key: @cell.Value</span>
                }
            </div>
            <div class="ls-admin-compact-list__actions">
                @if (!string.IsNullOrWhiteSpace(row.BadgeText))
                {
                    <span class="badge @row.BadgeClass">@row.BadgeText</span>
                }
                @foreach (var action in row.Actions)
                {
                    <a class="@action.CssClass" href="@action.Url">
                        <i class="bi @action.Icon me-1"></i>@action.Label
                    </a>
                }
            </div>
        </article>
    }
</div>
