@using System.Globalization
@using Lodestone.Application.DTOs.Admin

@{
    var shell = ViewData["AdminShell"] as AdminShellDto;
    var currentDate = shell?.CurrentDateLabel ?? DateTime.Now.ToString("dddd, dd MMM yyyy", CultureInfo.InvariantCulture);
    var adminName = shell?.AdminName ?? User.Identity?.Name ?? "Admin";
    var unreadNotifications = shell?.UnreadNotifications ?? 0;
    var unreadMessages = shell?.UnreadMessages ?? 0;
}

<div class="ls-admin-topnav__left">
    <a class="ls-admin-logo" asp-controller="Admin" asp-action="Index" aria-label="Lodestone admin home">
        <span class="ls-admin-logo__mark" aria-hidden="true">
            <i class="bi bi-bezier2"></i>
        </span>
        <span class="ls-admin-logo__text">Lodestone</span>
        <span class="ls-admin-logo__dot" aria-hidden="true"></span>
    </a>

    <div class="ls-admin-search" role="search">
        <i class="bi bi-search ls-admin-search__icon" aria-hidden="true"></i>
        <input class="ls-admin-search__input" type="search" placeholder="Search students, bookings, posts..." aria-label="Search" />
    </div>
</div>

<div class="ls-admin-topnav__right">
    <button class="ls-admin-iconbtn" type="button" aria-label="Notifications">
        <i class="bi bi-bell ls-admin-iconbtn__icon" aria-hidden="true"></i>
        <span class="ls-admin-iconbtn__badge" id="ls-unread-badge" aria-label="Unread notifications">@unreadNotifications</span>
    </button>

    <button class="ls-admin-iconbtn" type="button" aria-label="Messages">
        <i class="bi bi-chat-dots ls-admin-iconbtn__icon" aria-hidden="true"></i>
        @if (unreadMessages > 0)
        {
            <span class="ls-admin-iconbtn__badge ls-admin-iconbtn__badge--sm">@unreadMessages</span>
        }
    </button>

    <div class="ls-admin-topnav__date" id="ls-admin-date">@currentDate</div>



    <div class="ls-admin-profile dropdown">
        <button class="ls-admin-profile__btn" type="button" data-bs-toggle="dropdown" aria-expanded="false">
            <img class="ls-admin-profile__img" src="@(shell?.ProfileImageUrl ?? "/images/admin-avatar.svg")" alt="Admin profile" />
            <span class="ls-admin-profile__name">@adminName</span>
            <i class="bi bi-chevron-down ls-admin-profile__chevron" aria-hidden="true"></i>
        </button>
        <ul class="dropdown-menu dropdown-menu-end ls-admin-profile__menu" aria-label="Admin profile dropdown">
            <li><a class="dropdown-item" asp-controller="Admin" asp-action="Profile"><i class="bi bi-person me-2"></i>Profile</a></li>
            <li><a class="dropdown-item" asp-controller="Admin" asp-action="Settings"><i class="bi bi-gear me-2"></i>Settings</a></li>
            <li><hr class="dropdown-divider" /></li>
            <li>
                <form asp-controller="Account" asp-action="Logout" method="post" class="m-0">
                    <button class="dropdown-item text-danger" type="submit"><i class="bi bi-box-arrow-right me-2"></i>Logout</button>
                </form>
            </li>
        </ul>
    </div>
</div>
