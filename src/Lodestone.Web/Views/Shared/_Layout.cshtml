<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="theme-color" content="#F4EEE3" />
    <title>@ViewData["Title"] - Lodestone</title>

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Calistoga&family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500;600&display=swap" rel="stylesheet" />

    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    @await RenderSectionAsync("Styles", required: false)
</head>
<body>

    <header class="ls-nav" id="ls-nav">
        <div class="ls-shell ls-nav__inner">

            <a class="ls-brand" asp-controller="Home" asp-action="Index" aria-label="Lodestone home">
                Lodestone<span class="ls-brand__dot" aria-hidden="true"></span>
            </a>

            @*  Mobile dropdown menu (also holds desktop links via CSS)  *@
            <nav class="ls-nav__menu" id="ls-primary-nav" aria-label="Primary">
                <ul class="ls-nav__links">
                    <li><a asp-controller="Student"  asp-action="Index">Dashboard</a></li>
                    <li><a asp-controller="Journal"  asp-action="Index">Journal</a></li>
                    <li><a asp-controller="Forum"    asp-action="Index">Forum</a></li>
                    <li><a asp-controller="Booking"  asp-action="Index">Booking</a></li>
                </ul>

                @if (User.Identity?.IsAuthenticated == true)
                {
                    <span class="ls-nav__menu-user">@User.Identity!.Name</span>
                    <form class="ls-nav__menu-logout" asp-controller="Account" asp-action="Logout" method="post">
                        <button type="submit" class="ls-nav__menu-signout">Sign out</button>
                    </form>
                }
                else
                {
                    <a class="ls-nav__menu-signin" asp-controller="Account" asp-action="Login">Sign in</a>
                    <a class="ls-btn ls-btn--clay ls-btn--sm ls-nav__menu-cta" asp-controller="Account" asp-action="Register">Get started</a>
                }
            </nav>

            @*  Desktop right-side actions  *@
            <div class="ls-nav__actions">
                @if (User.Identity?.IsAuthenticated == true)
                {
                    <span class="ls-nav__user">@User.Identity!.Name</span>
                    <form asp-controller="Account" asp-action="Logout" method="post" style="margin:0;">
                        <button type="submit" class="ls-btn ls-btn--ghost ls-btn--sm">Sign out</button>
                    </form>
                }
                else
                {
                    <a class="ls-nav__signin" asp-controller="Account" asp-action="Login">Sign in</a>
                    <a class="ls-btn ls-btn--clay ls-btn--sm" asp-controller="Account" asp-action="Register">Get started</a>
                }
                <button class="ls-nav__toggle" type="button"
                        aria-controls="ls-primary-nav" aria-expanded="false" aria-label="Open menu">
                    <span aria-hidden="true"></span>
                    <span aria-hidden="true"></span>
                    <span aria-hidden="true"></span>
                </button>
            </div>

        </div>
    </header>

    <main role="main">
        @RenderBody()
    </main>

    <script src="https://cdn.jsdelivr.net/npm/@@studio-freight/lenis@1.0.42/dist/lenis.min.js" defer></script>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true" defer></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
