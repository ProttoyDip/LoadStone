@model Lodestone.Web.ViewModels.Auth.ForgotPasswordViewModel
@{
    ViewData["Title"] = "Forgot password";
    Layout = "_AuthLayout";
}

<header class="auth__header">
    <span class="auth__eyebrow">Account recovery</span>
    <h1 class="auth__title">Forgot your password?</h1>
    <p class="auth__subtitle">Enter your email and we'll send you a link to choose a new one.</p>
</header>

<form class="auth__form" asp-action="ForgotPassword" method="post">
    <div asp-validation-summary="ModelOnly" class="auth__alert" role="alert"></div>

    <div class="auth__field">
        <label class="auth__label" asp-for="Email">Email</label>
        <input class="auth__input" asp-for="Email" autocomplete="email" placeholder="you@university.edu" autofocus />
        <span class="field-validation-error" asp-validation-for="Email"></span>
    </div>

    <button class="auth__btn" type="submit">Send reset link</button>
</form>

<p class="auth__foot">
    Remembered it? <a class="auth__link" asp-action="Login">Back to sign in</a>
</p>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
