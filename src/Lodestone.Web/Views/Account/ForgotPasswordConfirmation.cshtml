@{
    ViewData["Title"] = "Check your email";
    Layout = "_AuthLayout";
}

<div class="auth__confirm">
    <div class="auth__confirm-icon" aria-hidden="true">✓</div>
    <header class="auth__header">
        <span class="auth__eyebrow">Account recovery</span>
        <h1 class="auth__title">Check your email</h1>
    </header>
    <p class="auth__subtitle">
        If an account exists for that address, we've sent a link to reset your password.
        The link expires shortly, so use it soon. Be sure to check your spam folder.
    </p>
</div>

<p class="auth__foot">
    <a class="auth__link" asp-action="Login">Back to sign in</a>
</p>
