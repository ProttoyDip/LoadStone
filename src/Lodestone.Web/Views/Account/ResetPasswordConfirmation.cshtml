@{
    ViewData["Title"] = "Password reset";
    Layout = "_AuthLayout";
}

<div class="auth__confirm">
    <div class="auth__confirm-icon" aria-hidden="true">✓</div>
    <header class="auth__header">
        <span class="auth__eyebrow">Account recovery</span>
        <h1 class="auth__title">Password updated</h1>
    </header>
    <p class="auth__subtitle">
        Your password has been reset. You can now sign in with your new password.
    </p>
</div>

<a class="auth__btn" asp-action="Login" style="text-align:center;text-decoration:none;">Sign in</a>
