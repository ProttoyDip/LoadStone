@model Lodestone.Web.ViewModels.Auth.ResetPasswordViewModel
@{
    ViewData["Title"] = "Reset password";
    Layout = "_AuthLayout";
}

<header class="auth__header">
    <span class="auth__eyebrow">Account recovery</span>
    <h1 class="auth__title">Choose a new password</h1>
    <p class="auth__subtitle">Set a new password for <strong>@Model.Email</strong>.</p>
</header>

<form class="auth__form" asp-action="ResetPassword" method="post">
    <div asp-validation-summary="ModelOnly" class="auth__alert" role="alert"></div>

    <input type="hidden" asp-for="Email" />
    <input type="hidden" asp-for="Token" />

    <div class="auth__field">
        <label class="auth__label" asp-for="Password">New password</label>
        <input class="auth__input" asp-for="Password" autocomplete="new-password" placeholder="At least 8 characters" autofocus />
        <span class="field-validation-error" asp-validation-for="Password"></span>
    </div>

    <div class="auth__field">
        <label class="auth__label" asp-for="ConfirmPassword"></label>
        <input class="auth__input" asp-for="ConfirmPassword" autocomplete="new-password" placeholder="Re-enter your password" />
        <span class="field-validation-error" asp-validation-for="ConfirmPassword"></span>
    </div>

    <button class="auth__btn" type="submit">Reset password</button>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
