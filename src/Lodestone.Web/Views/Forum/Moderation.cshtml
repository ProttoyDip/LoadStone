@model IReadOnlyList<Lodestone.Application.DTOs.Forum.ForumPostDto>
@{
    ViewData["Title"] = "Forum Moderation";
}

@section Styles {
    <link rel="stylesheet" href="~/css/forum.css" asp-append-version="true" />
}

<div class="forum-page">
    <section class="forum-subhero">
        <div class="forum-shell">
            <nav class="forum-breadcrumb" aria-label="Breadcrumb">
                <a asp-controller="Forum" asp-action="Index">Forum</a>
                <span aria-hidden="true">/</span>
                <span aria-current="page">Moderation</span>
            </nav>
            <div class="forum-subhero__content">
                <div>
                    <p class="forum-kicker"><span aria-hidden="true"></span>Moderation queue</p>
                    <h1>Review flagged discussions.</h1>
                    <p>Assess each report carefully and choose whether the discussion should remain available to the community.</p>
                </div>
            </div>
        </div>
    </section>

    <main class="forum-shell forum-content">
        <section aria-labelledby="flagged-posts-title">
            <div class="forum-section-head forum-section-head--compact">
                <div>
                    <p class="forum-section-eyebrow">Review required</p>
                    <h2 id="flagged-posts-title">@Model.Count @(Model.Count == 1 ? "flagged post" : "flagged posts")</h2>
                </div>
                <p>Approving makes a post available; removing takes it out of the public discussion.</p>
            </div>

            @if (Model.Count == 0)
            {
                <div class="forum-empty" role="status">
                    <span class="forum-empty__index" aria-hidden="true">00</span>
                    <div>
                        <h3>The moderation queue is clear.</h3>
                        <p>There are no flagged discussions awaiting review.</p>
                    </div>
                </div>
            }
            else
            {
                <div class="forum-post-list" aria-label="Flagged posts awaiting review">
                    @foreach (var post in Model)
                    {
                        <article class="forum-post-card">
                            <div class="forum-post-card__meta">
                                <span>Post #@post.Id</span>
                                <span aria-hidden="true">·</span>
                                <span>Status: @post.Status</span>
                                <span aria-hidden="true">·</span>
                                <time datetime="@post.CreatedAtUtc.ToString("O")">@post.CreatedAtUtc.ToString("dd MMM yyyy, HH:mm") UTC</time>
                            </div>
                            <h3>@post.Title</h3>
                            <p class="forum-post-card__excerpt">@post.Body</p>

                            <form class="forum-form__footer" action="/Forum/Review" method="post" aria-label="Moderation decision for post @post.Id">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="postId" value="@post.Id" />
                                <p>Review this post against the community guidelines before making a decision.</p>
                                <div>
                                    <button class="ls-btn ls-btn--ghost ls-btn--sm" type="submit" name="publish" value="true">Approve post</button>
                                    <button class="ls-btn ls-btn--clay ls-btn--sm" type="submit" name="publish" value="false">Remove post</button>
                                </div>
                            </form>
                        </article>
                    }
                </div>
            }
        </section>
    </main>
</div>
